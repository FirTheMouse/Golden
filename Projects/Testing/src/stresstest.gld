Vec2 {
    int x;
    int y;

    int add(int ox, int oy) {
        print(ox);
        print(oy);
    }

    int negate(int val) {
        print(val);
    }
}

Vec3 {
    int x;
    int y;
    int z;

    int dot(int ox, int oy, int oz) {
        print(ox);
        print(oy);
        print(oz);
    }

    int scale(int factor) {
        print(factor);
    }

    int zero(int a, int b, int c) {
        print(a);
    }
}

Mat2 {
    int a;
    int b;
    int c;
    int d;

    int transform(int val) {
        print(val);
    }

    int trace(int x, int y) {
        print(x);
        print(y);
    }
}

Mat3 {
    int a;
    int b;
    int c;
    int d;
    int e;
    int f;
    int g;
    int h;
    int i;

    int apply(int val) {
        print(val);
    }
}

Color {
    int r;
    int g;
    int b;
    int a;

    int blend(int other) {
        print(other);
    }

    int brighten(int amount) {
        print(amount);
    }
}

Rect {
    int x;
    int y;
    int w;
    int h;

    int area(int width, int height) {
        print(width);
        print(height);
    }

    int translate(int dx, int dy) {
        print(dx);
        print(dy);
    }
}

int a = 1;
int b = 2;
