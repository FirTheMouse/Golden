int x = 1 + 2;
int y = 3 * 4;
int z = x + y;
int w = z * 2;
int q = w + x * 3;
int s = q * y + z;
int t = s + w * q;
int u = t * 2 + s;
int aa = u + t * x;
int bb = aa * 3 + u;
int cc = bb + aa * y;
int dd = cc * z + bb;
int ee = dd + cc * 2;
int ff = ee * x + dd;
int gg = ff + ee * 3;
int hh = gg * y + ff;
int ii = hh + gg * z;
int jj = ii * 2 + hh;
int kk = jj + ii * x;
int ll = kk * 3 + jj;