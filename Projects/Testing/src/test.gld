num {
    int a;
    int b;
}

num x;
x.a = 3;
x.b = 7;

num* p;
p = &x;
(*p).a = 10;
print("x.a after pointer write: ", x.a);
print("x.b: ", x.b);

int i = 0;
while(i < 3) {
    i = i + 1;
    print("i: ", i);
}



int result = 15;
if(result > 10) {
    print("Result is over 10");
} else if(result > 5) {
    print("Result is over 5");
} else {
    print("Result is 5 or under");
}


int h = 5;
int k = 3;
int* pa;
pa = &h;
print("k via pointer: ", (*pa));
(*pa) = 20;
print("h after pointer write: ", h);
