num {
    int x;

    int add(int val) {
        x = x+val;
        return x;
    }
}

int main() {
    print("Hello!");
    num c;
    num* ptr = &c;
    c.x = 1;
    int n[2];
    n[0] = 4;
    n[1] = 2;
    print("Starting value (from a ptr): ",(*ptr).x);

    (*ptr).add(n[0]);
    c.add(n[1]);

    print("Final value: ",c.x);
}

main();

